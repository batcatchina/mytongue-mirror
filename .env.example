# ========================================
# 舌镜前端环境配置模板
# ========================================
# 复制此文件为 .env 并填入实际值

# 扣子API配置
VITE_API_BASE_URL=https://api.coze.cn/v1

# Bot ID（在智能体发布页面获取）
VITE_BOT_ID=YOUR_BOT_ID_HERE

# API Token（在个人设置 → API Token管理 创建）
VITE_API_TOKEN=YOUR_API_TOKEN_HERE

# ========================================
# 可选配置
# ========================================

# 工作流ID（如果使用工作流而非智能体）
# VITE_WORKFLOW_ID=YOUR_WORKFLOW_ID_HERE

# 输出语言（默认中文）
# VITE_OUTPUT_LANGUAGE=中文
