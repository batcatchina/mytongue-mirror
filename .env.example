# 正和系统对接配置
# 复制此文件为 .env.local 并填入实际值

# ===================
# 正和系统 API 配置
# ===================

# 正和API地址（测试环境/生产环境）
VITE_ZHENGHE_API_URL=https://api-test.zhenghe.ai/v1

# 舌镜Agent在正和系统的ID（注册后获得）
VITE_ZHENGHE_AGENT_ID=

# ===================
# 测试配置（仅开发调试用）
# ===================

# 测试用API Key
VITE_TEST_ZHENGHE_API_KEY=

# 测试用API Secret
VITE_TEST_ZHENGHE_API_SECRET=

# 测试用户ID
VITE_TEST_USER_ID=

# 测试账户ID
VITE_TEST_ACCOUNT_ID=

# 测试推荐码
VITE_TEST_REFERRAL_CODE=

# ===================
# 支付宝配置
# ===================

# 支付宝应用 AppId
ALIPAY_APP_ID=

# 支付宝应用私钥（RSA2）
ALIPAY_PRIVATE_KEY=

# 支付宝公钥
ALIPAY_PUBLIC_KEY=

# 支付宝网关地址
# 沙箱环境：https://openapi-sandbox.dl.alipaydev.com/gateway.do
# 正式环境：https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# 支付回调域名（用于构造 notify_url 和 return_url）
ALIPAY_NOTIFY_DOMAIN=

# 前端地址（用于 return_url 跳转）
ALIPAY_FRONTEND_URL=http://localhost:5173
