{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    },
    {
      "source": "/api/diagnose",
      "destination": "/api/tongue-ai/diagnose"
    },
    {
      "source": "/api/tongue",
      "destination": "/api/tongue-ai/tongue"
    },
    {
      "source": "/api/result",
      "destination": "/api/tongue-ai/result"
    },
    {
      "source": "/api/ai/inquiry/generate",
      "destination": "/api/tongue-ai/inquiry-generate"
    },
    {
      "source": "/api/ai/inquiry/submit",
      "destination": "/api/tongue-ai/inquiry-submit"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "functions": {
    "api/alipay/*.js": {
      "maxDuration": 10
    }
  }
}
