      { value: '详细模式', label: '详细模式', description: '完整辨证分析、选穴方案和生活调护' },
    ],
  };
}

/**
 * 健康检查
 */
export async function healthCheck(): Promise<boolean> {
  try {
    if (!BOT_ID || !API_TOKEN) return false;
    return true;
  } catch {
    return false;
  }
}

export function getApiConfig() {
  return {
    baseUrl: API_BASE_URL,
    botId: BOT_ID ? `${BOT_ID.slice(0, 8)}...` : '未配置',
    hasToken: !!API_TOKEN,
  };
}
